#!/bin/sh

[ $# -gt 0 ] || {
    echo "Usage: $0 HOST..."
    exit 1
}

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

# For each host and IP version, materialize a copy of the suite with the
# connect-to, IP version and per-host skips baked into every request, so a
# single `hurl --test` can run them all in parallel.
for host in "$@"; do

    # comments.luffy.cx is only served by web03, so skip it elsewhere.
    case $host in
        web03*) skipcomments=false ;;
        *) skipcomments=true ;;
    esac

    for version in ipv4 ipv6; do
        awk -v host="$host" -v version="$version" -v skipcomments="$skipcomments" '
            /^[A-Z]+[ \t]+https?:\/\// {
                print
                print "[Options]"
                print "connect-to: :443:" host ":443"
                print "connect-to: :80:" host ":80"
                print version ": true"
                if (skipcomments == "true" && $2 ~ /comments\.luffy\.cx/)
                    print "skip: true"
                next
            }
            /^\[Options\]$/ { next }   # merge any existing options into ours
            { print }
        ' tests.hurl > "$tmpdir/$host-$version.hurl"
    done
done

hurl --test \
     --connect-timeout 2 \
     --max-time 2 \
     "$tmpdir"/*.hurl
